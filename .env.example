# Face-service environment variables (copy relevant ones into Railway → Variables).
# Every var below is OPTIONAL — the service boots with the documented defaults.
# The decision/quality/liveness tuning lives in config.py; these override at runtime.

# ── Recognition decision ──────────────────────────────────────────────────────
# Cosine-similarity match threshold on L2-normalised Buffalo_L embeddings.
# Buffalo_L genuine pairs sit ~0.45–0.85; DO NOT set this to 0.75+ (rejects real
# employees). Calibrated default is 0.45.
FACE_MATCH_THRESHOLD=0.45

# ── Passive anti-spoofing (MiniFASNet PAD) ────────────────────────────────────
# Min p_real for a frame burst to count as a LIVE person. Default 0.25 is tuned
# low for cheap test cameras; raise toward 0.45–0.5 for good production hardware.
FACE_LIVENESS_THRESHOLD=0.25

# ── Quality gate (sunglasses / reflective-lens catch) ─────────────────────────
# Min eye-region skin fraction; below this the eyes are treated as occluded.
# Default 0.10 favours dim/low-res cameras; raise to 0.20–0.26 for good hardware.
FACE_EYE_MIN_SKIN=0.22

# ── InsightFace model home ────────────────────────────────────────────────────
# Directory holding  models/buffalo_l/*.onnx . DEFAULTS to the pack BUNDLED in
# this repo (face-service/insightface_home), so there is NO runtime download.
# Only set this to override with an external pack location.
# INSIGHTFACE_HOME=/app/insightface_home

# ── Server port ───────────────────────────────────────────────────────────────
# Railway injects PORT automatically; the app binds 0.0.0.0:$PORT (default 8000
# locally). No need to set this on Railway.
# PORT=8000
